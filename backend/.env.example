# Server Configuration
PORT=5000
NODE_ENV=development

# Supabase Credentials
# Retrieve these from your Supabase Project Settings -> API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your-supabase-service-role-or-anon-key

# JWT Token Configuration
JWT_SECRET=your_jwt_signing_secret_key_minimum_32_characters

# Security Configurations
# Secret registration code to prevent unauthorized admin registration
ADMIN_REGISTRATION_CODE=AdminSecureSignupSecretCode2026

# Email/SMTP Configuration (Optional - for notifications)
EMAIL_HOST=smtp.mailtrap.io
EMAIL_PORT=2525
EMAIL_USER=your_smtp_username
EMAIL_PASS=your_smtp_password
EMAIL_FROM=noreply@yourclinic.com

# WhatsApp Config (Business number for user-facing links)
WHATSAPP_PHONE=919876543210
